{
	"name": "n8n-nodes-mongodb-vector-search",
	"version": "2.0.4",
	"description": "Custom n8n node for high-performance MongoDB Vector Search, standard queries, and custom JSON aggregations.",
	"license": "MIT",
	"homepage": "https://github.com/DanEvenSegler/n8n-nodes-mongodb-vector-search",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Dan Even segler",
		"email": "danevensegler08@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/DanEvenSegler/n8n-nodes-mongodb-vector-search.git"
	},
	"main": "dist/nodes/MongoDbVectorSearch/MongoDbVectorSearch.node.js",
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"prepare": "npm run build",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"nodes": [
			"dist/nodes/MongoDbVectorSearch/MongoDbVectorSearch.node.js",
			"dist/nodes/MongoDbVectorSearchVectorStore/MongoDbVectorSearchVectorStore.node.js",
			"dist/nodes/MongoDbAiSearch/MongoDbAiSearch.node.js"
		]
	},
	"dependencies": {
		"@langchain/core": "^0.2.0 || ^0.3.0 || ^1.0.0",
		"mongodb": "^6.5.0"
	},
	"devDependencies": {
		"@n8n/node-cli": "^0.23.0",
		"@types/node": "^18.16.0",
		"typescript": "~5.3.3",
		"n8n-workflow": "^1.0.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}